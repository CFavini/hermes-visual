<!doctype html>
<html lang="pt-BR">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Hermes v0.4.3 — Escritório Vivo</title>
<style>
  :root{
    --bg:#070d14; --bg-2:#0b1722; --panel:#0e1b28; --panel-2:#102234;
    --line:#1d3145; --line-soft:#16283a;
    --ink:#eaf3fb; --ink-dim:#8aa1b6; --ink-faint:#5a7187;
    --gold:#d6ad60; --gold-soft:#9a7d40;
    --danger:#ff4d5a; --warn:#ffb020; --ok:#4dd4ac; --quar:#8f5cff;
    --floor:#16344a; --floor-hi:#1d4258; --wall-r:#0d2334; --wall-l:#091a28;
    --shadow:0 18px 40px rgba(0,0,0,.55);
  }
  *{box-sizing:border-box}
  html,body{margin:0;height:100%}
  body{
    background:
      radial-gradient(1200px 700px at 70% -10%, rgba(214,173,96,.06), transparent 60%),
      radial-gradient(900px 600px at 10% 110%, rgba(143,92,255,.05), transparent 55%),
      var(--bg);
    color:var(--ink);
    font:14px/1.45 "Inter",system-ui,-apple-system,"Segoe UI",Roboto,sans-serif;
    overflow:hidden;
  }
  .app{display:grid;grid-template-columns:264px 1fr 320px;grid-template-rows:1fr auto;height:100vh}
  @media (max-width:1100px){ .app{grid-template-columns:0 1fr 0} .rail,.inspector{display:none} }

  /* ---------- LEFT COMMAND RAIL ---------- */
  .rail{grid-row:1/3;border-right:1px solid var(--line);background:linear-gradient(180deg,var(--panel),var(--bg-2));
        padding:18px 16px;display:flex;flex-direction:column;gap:16px;overflow:auto}
  .brand{display:flex;gap:11px;align-items:center}
  .brand .seal{width:42px;height:42px;border-radius:11px;display:grid;place-items:center;font-size:22px;font-weight:700;
        color:#1a130a;background:linear-gradient(135deg,var(--gold),#b88a34);box-shadow:0 0 0 1px rgba(214,173,96,.4),0 8px 18px rgba(214,173,96,.25)}
  .brand .eyebrow{font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:var(--gold-soft);margin:0}
  .brand h1{font-size:15px;margin:1px 0 0;letter-spacing:.01em}
  .brand small{color:var(--ink-faint);font-size:11px}

  .mode-pill{display:inline-flex;align-items:center;gap:7px;font-size:11px;font-weight:600;letter-spacing:.04em;
        padding:6px 10px;border-radius:999px;border:1px solid var(--line);background:#0a1622;color:var(--ink-dim);width:fit-content}
  .mode-pill .led{width:8px;height:8px;border-radius:50%;background:var(--ink-faint)}
  .mode-pill.live{color:var(--ok);border-color:rgba(77,212,172,.4)} .mode-pill.live .led{background:var(--ok);box-shadow:0 0 8px var(--ok)}
  .mode-pill.offline{color:var(--warn);border-color:rgba(255,176,32,.4)} .mode-pill.offline .led{background:var(--warn)}

  .rail h2{font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--ink-faint);margin:6px 0 0}
  .btn{appearance:none;border:1px solid var(--line);background:#0c1a28;color:var(--ink);font:inherit;font-weight:600;
        padding:11px 13px;border-radius:10px;cursor:pointer;text-align:left;display:flex;justify-content:space-between;align-items:center;gap:8px}
  .btn:hover{border-color:var(--gold-soft);background:#10212f}
  .btn.primary{background:linear-gradient(135deg,var(--gold),#bd9039);color:#191205;border-color:transparent}
  .btn.primary:hover{filter:brightness(1.06)}
  .btn small{font-weight:500;color:var(--ink-faint)}
  .btn.primary small{color:#3a2c0c}
  .btn:disabled{opacity:.45;cursor:not-allowed}

  .legend{display:flex;flex-direction:column;gap:6px;font-size:11.5px;color:var(--ink-dim)}
  .legend .row{display:flex;align-items:center;gap:8px}
  .legend .sw{width:12px;height:12px;border-radius:3px;border:1px solid rgba(255,255,255,.15)}

  .lock{margin-top:auto;font-size:11px;color:var(--ink-faint);border:1px dashed var(--line);border-radius:9px;padding:9px 11px;background:#0a1420}
  .lock b{color:var(--ink-dim);display:block;margin-bottom:2px;letter-spacing:.03em}

  /* ---------- STAGE ---------- */
  .stage{position:relative;overflow:hidden;cursor:grab;background:
      radial-gradient(1100px 800px at 50% 35%, rgba(28,58,82,.35), transparent 70%);}
  .stage.dragging{cursor:grabbing}
  .stage-top{position:absolute;z-index:8;left:18px;top:14px;right:18px;display:flex;justify-content:space-between;align-items:flex-start;pointer-events:none}
  .stage-title .eyebrow{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--gold-soft);margin:0}
  .stage-title h3{margin:2px 0 0;font-size:18px;letter-spacing:.01em;text-shadow:0 2px 10px rgba(0,0,0,.6)}
  .stage-title p{margin:3px 0 0;font-size:11.5px;color:var(--ink-dim);max-width:430px}
  .zoomctl{pointer-events:auto;display:flex;gap:6px}
  .zoomctl button{width:34px;height:34px;border-radius:9px;border:1px solid var(--line);background:#0c1a28cc;color:var(--ink);
        font-size:16px;cursor:pointer;backdrop-filter:blur(4px)}
  .zoomctl button:hover{border-color:var(--gold-soft)}

  #viewport{position:absolute;inset:0}
  #world{position:absolute;left:0;top:0;transform-origin:0 0;will-change:transform}
  #floorplan{position:absolute;left:0;top:0;display:block}
  #tokens{position:absolute;left:0;top:0;pointer-events:none}

  .banner{position:absolute;z-index:8;left:50%;bottom:14px;transform:translateX(-50%);
        font-size:10.5px;letter-spacing:.14em;text-transform:uppercase;font-weight:700;color:#0c0a05;
        background:linear-gradient(90deg,var(--gold),#caa04e);padding:6px 16px;border-radius:999px;
        box-shadow:0 6px 18px rgba(0,0,0,.4);white-space:nowrap}

  /* ---------- AGENT TOKENS ---------- */
  .agent{position:absolute;width:46px;transform:translate(-50%,-100%);pointer-events:auto;cursor:pointer;z-index:5;text-align:center}
  .agent-body{width:38px;height:46px;margin:0 auto;border-radius:13px 13px 9px 9px;display:grid;place-items:center;
        font-size:19px;color:#0a0f15;
        background:linear-gradient(180deg, color-mix(in srgb, var(--c) 86%, white 14%), var(--c));
        border:1px solid rgba(255,255,255,.25);
        box-shadow:0 7px 10px rgba(0,0,0,.5), inset 0 2px 4px rgba(255,255,255,.3)}
  .agent::after{content:"";position:absolute;left:50%;bottom:-5px;transform:translateX(-50%);
        width:30px;height:9px;border-radius:50%;background:rgba(0,0,0,.45);filter:blur(2px);z-index:-1}
  .agent-name{margin-top:3px;font-size:10px;font-weight:600;color:#eaf6ff;text-shadow:0 1px 3px #000;white-space:nowrap}
  .agent-bubble{position:absolute;left:50%;bottom:62px;transform:translateX(-50%);font-size:9.5px;line-height:1;
        padding:4px 7px;border-radius:999px;white-space:nowrap;color:var(--ink);
        background:rgba(6,12,18,.94);border:1px solid var(--line);box-shadow:0 4px 10px rgba(0,0,0,.4)}
  .agent-bubble::after{content:"";position:absolute;left:50%;bottom:-4px;transform:translateX(-50%);
        border:4px solid transparent;border-top-color:rgba(6,12,18,.94)}
  .agent.sel .agent-body{box-shadow:0 0 0 3px var(--gold),0 7px 12px rgba(0,0,0,.6)}
  .agent.crit .agent-body{box-shadow:0 0 0 3px var(--danger),0 0 22px rgba(255,77,90,.7)}

  .agent.st-working .agent-body{animation:bob 1.2s ease-in-out infinite}
  .agent.st-idle .agent-body{animation:breath 2.6s ease-in-out infinite}
  .agent.st-audit .agent-body{animation:scan 1.8s ease-in-out infinite}
  .agent.st-wait .agent-body{animation:wait 2s ease-in-out infinite}
  .agent.st-quar .agent-body{animation:quar 1.7s ease-in-out infinite}
  .agent.st-legal .agent-body{animation:legal 1.6s ease-in-out infinite}
  .agent.walking .agent-body{animation:walk .42s ease-in-out infinite}

  @keyframes bob{0%,100%{transform:translateY(0)}25%{transform:translateY(-4px)}50%{transform:translateY(0)}75%{transform:translateY(-2px)}}
  @keyframes breath{0%,100%{transform:translateY(0) scale(1)}50%{transform:translateY(-2px) scale(1.02)}}
  @keyframes scan{0%,100%{box-shadow:0 7px 10px rgba(0,0,0,.5),0 0 0 0 rgba(255,176,32,.5)}50%{box-shadow:0 7px 10px rgba(0,0,0,.5),0 0 0 8px rgba(255,176,32,0)}}
  @keyframes wait{0%,100%{box-shadow:0 7px 10px rgba(0,0,0,.5),0 0 0 0 rgba(214,173,96,.6)}50%{box-shadow:0 7px 10px rgba(0,0,0,.5),0 0 16px 2px rgba(214,173,96,.5)}}
  @keyframes quar{0%,100%{box-shadow:0 7px 10px rgba(0,0,0,.5),0 0 10px 0 rgba(143,92,255,.5)}50%{box-shadow:0 7px 10px rgba(0,0,0,.5),0 0 26px 4px rgba(143,92,255,.8)}}
  @keyframes legal{0%,100%{filter:none}50%{filter:brightness(1.25)}}
  @keyframes walk{0%,100%{transform:translateY(0) rotate(-3deg)}50%{transform:translateY(-3px) rotate(3deg)}}

  /* ---------- INSPECTOR ---------- */
  .inspector{grid-row:1/3;border-left:1px solid var(--line);background:linear-gradient(180deg,var(--panel),var(--bg-2));
        padding:16px;display:flex;flex-direction:column;gap:14px;overflow:auto}
  .card{border:1px solid var(--line);border-radius:12px;background:var(--panel-2);padding:13px 14px}
  .card h4{margin:0 0 10px;font-size:10px;letter-spacing:.15em;text-transform:uppercase;color:var(--ink-faint);
        display:flex;justify-content:space-between;align-items:center}
  .card h4 .tag{font-size:10px;letter-spacing:.03em;text-transform:none;color:var(--gold);font-weight:600}
  .insp-head{display:flex;gap:11px;align-items:center}
  .insp-avatar{width:44px;height:44px;border-radius:12px;display:grid;place-items:center;font-size:21px;color:#0a0f15;flex:none;
        background:linear-gradient(180deg,color-mix(in srgb,var(--c,#888) 85%,white 15%),var(--c,#888));border:1px solid rgba(255,255,255,.25)}
  .insp-head .nm{font-size:15px;font-weight:700} .insp-head .rl{font-size:11.5px;color:var(--ink-dim)}
  .kv{display:grid;grid-template-columns:auto 1fr;gap:5px 12px;font-size:12px;margin-top:11px}
  .kv dt{color:var(--ink-faint)} .kv dd{margin:0;text-align:right;color:var(--ink)}
  .chip{display:inline-block;font-size:10px;font-weight:600;padding:2px 8px;border-radius:999px;border:1px solid var(--line)}
  .chip.s4{color:var(--quar);border-color:rgba(143,92,255,.45)}
  .chip.block{color:var(--danger);border-color:rgba(255,77,90,.45)}
  .empty{color:var(--ink-faint);font-size:12.5px;text-align:center;padding:14px 4px}

  .tasklist{display:flex;flex-direction:column;gap:8px;max-height:280px;overflow:auto}
  .task{border:1px solid var(--line);border-left-width:3px;border-radius:9px;padding:8px 10px;background:#0b1825}
  .task .t{font-size:12.5px;font-weight:600;line-height:1.3}
  .task .m{display:flex;gap:6px;margin-top:5px;flex-wrap:wrap}
  .pri{font-size:9.5px;font-weight:700;padding:1px 6px;border-radius:5px}
  .pri.P0{background:var(--danger);color:#fff}.pri.P1{background:var(--warn);color:#241700}.pri.P2{background:#2a3e51;color:var(--ink-dim)}
  .st{font-size:9.5px;color:var(--ink-dim);padding:1px 6px;border-radius:5px;border:1px solid var(--line)}
  .task.blocked{border-left-color:var(--danger)} .task.in_progress{border-left-color:var(--ok)} .task.pending{border-left-color:var(--warn)}

  /* ---------- STATUS BAR ---------- */
  .statusbar{grid-column:2/3;display:flex;gap:18px;align-items:center;flex-wrap:wrap;
        border-top:1px solid var(--line);background:#091521;padding:9px 18px;font-size:11.5px;color:var(--ink-dim)}
  .statusbar b{color:var(--ink);font-weight:600}
  .statusbar .v0{color:var(--gold);font-weight:700;letter-spacing:.04em}
  .statusbar .sep{width:1px;height:14px;background:var(--line)}

  /* ---------- TOAST ---------- */
  #toast{position:fixed;left:50%;bottom:64px;transform:translateX(-50%) translateY(16px);z-index:20;opacity:0;
        max-width:520px;background:#0c1a28;border:1px solid var(--gold-soft);color:var(--ink);
        padding:11px 16px;border-radius:11px;box-shadow:var(--shadow);font-size:12.5px;transition:opacity .25s,transform .25s;pointer-events:none}
  #toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

  @media (prefers-reduced-motion: reduce){
    .agent .agent-body{animation:none !important}
    #toast{transition:none}
  }
</style>
</head>
<body>
<div class="app">
  <!-- LEFT RAIL -->
  <aside class="rail">
    <div class="brand">
      <div class="seal">♛</div>
      <div>
        <p class="eyebrow">Arconte Supremo</p>
        <h1>Hermes Visual</h1>
        <small>Escritório Vivo · v0.4.3</small>
      </div>
    </div>
    <span id="mode" class="mode-pill"><span class="led"></span><span id="mode-label">conectando…</span></span>

    <h2>Comando local</h2>
    <button class="btn primary" id="btn-cycle">Rodar Ciclo Hermes <small>POST /api/cycle</small></button>
    <button class="btn" id="btn-refresh">Atualizar dados <small>GET</small></button>
    <button class="btn" id="btn-reset">Recentralizar câmera <small>⌂</small></button>

    <h2>Legenda de salas</h2>
    <div class="legend">
      <div class="row"><span class="sw" style="background:#16344a"></span>Operacional (S0–S2)</div>
      <div class="row"><span class="sw" style="background:#3b1d5f"></span>Cofre / quarentena (S4)</div>
      <div class="row"><span class="sw" style="background:#5a1620"></span>Frente crítica / bloqueada</div>
    </div>

    <div class="lock">
      <b>Trava operacional</b>
      Local. Sem cloud, sem ação externa, sem pessoa jurídica. Sala e estado vêm da API; o caminhar é coreografia visual sobre o estado real.
    </div>
  </aside>

  <!-- STAGE -->
  <section class="stage" id="stage">
    <div class="stage-top">
      <div class="stage-title">
        <p class="eyebrow">Planta isométrica viva</p>
        <h3>O Conselho do Arconte em operação</h3>
        <p>Arraste para mover · scroll para zoom · clique num agente ou numa sala.</p>
      </div>
      <div class="zoomctl">
        <button id="zoom-out" title="Menos zoom">−</button>
        <button id="zoom-in" title="Mais zoom">+</button>
      </div>
    </div>
    <div id="viewport">
      <div id="world">
        <svg id="floorplan" xmlns="http://www.w3.org/2000/svg"></svg>
        <div id="tokens"></div>
      </div>
    </div>
    <div class="banner">Simulação local — sem ação externa</div>
  </section>

  <!-- INSPECTOR -->
  <aside class="inspector">
    <div class="card">
      <h4>Ficha do agente <span class="tag" id="insp-tag">nenhum</span></h4>
      <div id="inspector"><div class="empty">Clique num agente no escritório para ver sua ficha.</div></div>
    </div>
    <div class="card">
      <h4>Tarefas <span class="tag" id="task-filter">todas as salas</span></h4>
      <div id="tasks" class="tasklist"><div class="empty">Carregando tarefas…</div></div>
    </div>
  </aside>

  <!-- STATUS BAR -->
  <footer class="statusbar">
    <span class="v0">v0.4.3 sandbox</span><span class="sep"></span>
    <span id="sb-cycle">Ciclo: não rodado</span><span class="sep"></span>
    <span id="sb-critical">Frente crítica: <b>n/d</b></span><span class="sep"></span>
    <span id="sb-p0">P0: <b>n/d</b></span><span class="sep"></span>
    <span id="sb-alerts">Alertas abertos: <b>0</b></span><span class="sep"></span>
    <span id="sb-ext">Ação externa: <b>0</b></span>
  </footer>
</div>

<div id="toast" role="status" aria-live="polite"></div>

<script>
"use strict";
/* ============================================================================
   Hermes v0.4.3 — Escritório Vivo (isométrico)
   Frontend puro. Lê endpoints reais; não altera backend/SQLite/v0.4.2.
   Fallback de PRÉVIA OFFLINE = snapshot exato do SQLite v0.4.2 (dados reais),
   usado apenas quando a API está inacessível. Ao vivo sempre tem prioridade.
   ============================================================================ */

