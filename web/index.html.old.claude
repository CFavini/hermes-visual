 app declare execução externa quando só houve simulação local.", "priority": "P1", "status": "in_progress", "risk_level": 3, "requires_favini": 0, "requires_legal": 0, "external_action_allowed": 0, "is_simulated": 1, "data_classification": "S1", "due_at": null, "created_at": "2026-06-19 21:40:53", "updated_at": "2026-06-19 21:40:53", "completed_at": null, "company_name": "Conselho do Arconte", "room_name": "Conselho / Reunião", "agent_name": "Auditor Zero"}, {"id": 7, "company_id": 9, "room_id": 9, "assigned_agent_id": 7, "title": "Monitorar Radar Argentina como hipótese", "description": "Registrar observação sem instrução de abertura de empresa.", "priority": "P1", "status": "pending", "risk_level": 3, "requires_favini": 0, "requires_legal": 1, "external_action_allowed": 0, "is_simulated": 1, "data_classification": "S0", "due_at": null, "created_at": "2026-06-19 21:40:53", "updated_at": "2026-06-19 21:40:53", "completed_at": null, "company_name": "Radar Argentina", "room_name": "Radar Jurisdicional", "agent_name": "Nomos"}, {"id": 8, "company_id": 2, "room_id": 2, "assigned_agent_id": 1, "title": "Organizar Conselho Visual do Arconte", "description": "Distribuir agentes no Pixel Office e dar leitura rápida de estado.", "priority": "P1", "status": "pending", "risk_level": 2, "requires_favini": 0, "requires_legal": 0, "external_action_allowed": 0, "is_simulated": 1, "data_classification": "S1", "due_at": null, "created_at": "2026-06-19 21:40:53", "updated_at": "2026-06-19 21:40:53", "completed_at": null, "company_name": "Conselho do Arconte", "room_name": "Conselho / Reunião", "agent_name": "Arconte Supremo"}], "alerts": [{"id": 1, "company_id": 3, "task_id": 2, "agent_id": 7, "title": "COS regulado e bloqueado", "risk_type": "regulatorio", "severity": 5, "status": "open", "blocks_progress": 1, "requires_favini": 1, "data_classification": "S2", "message": "COS envolve seguros, sinistros, IA, dados e terceiros; não pode operar externamente.", "created_at": "2026-06-19 21:40:53", "resolved_at": null, "company_name": "COS Virtual", "agent_name": "Nomos"}, {"id": 2, "company_id": 7, "task_id": 3, "agent_id": 3, "title": "Cofre GD S4", "risk_type": "quarentena", "severity": 5, "status": "open", "blocks_progress": 1, "requires_favini": 1, "data_classification": "S4", "message": "Genoma Digital aparece apenas como cofre visual S4, sem conteúdo bruto.", "created_at": "2026-06-19 21:40:53", "resolved_at": null, "company_name": "Cofre Genoma Digital", "agent_name": "Cerberus"}, {"id": 3, "company_id": 4, "task_id": null, "agent_id": 8, "title": "Contabilidade exige humano responsável", "risk_type": "responsabilidade_tecnica", "severity": 4, "status": "open", "blocks_progress": 1, "requires_favini": 0, "data_classification": "S1", "message": "Agentes podem preparar simulação, mas não assumir atos privativos.", "created_at": "2026-06-19 21:40:53", "resolved_at": null, "company_name": "Contabilidades Virtuais", "agent_name": "Themis"}, {"id": 4, "company_id": 9, "task_id": 7, "agent_id": 7, "title": "Argentina é hipótese, não lei operacional", "risk_type": "hipotese_juridica", "severity": 3, "status": "open", "blocks_progress": 0, "requires_favini": 0, "data_classification": "S0", "message": "Radar Argentina observa tendência, sem instrução de abertura de empresa.", "created_at": "2026-06-19 21:40:53", "resolved_at": null, "company_name": "Radar Argentina", "agent_name": "Nomos"}, {"id": 5, "company_id": 5, "task_id": 4, "agent_id": 2, "title": "Aitherion ainda não é pessoa jurídica", "risk_type": "governanca", "severity": 3, "status": "open", "blocks_progress": 0, "requires_favini": 1, "data_classification": "S2", "message": "Interface deve mostrar estruturação, não operação societária real.", "created_at": "2026-06-19 21:40:53", "resolved_at": null, "company_name": "Aitherion Labs em estruturação", "agent_name": "Auditor Zero"}, {"id": 6, "company_id": 6, "task_id": null, "agent_id": 3, "title": "Vantion/LUNA requer proteção técnica", "risk_type": "pi_tecnica", "severity": 4, "status": "open", "blocks_progress": 1, "requires_favini": 1, "data_classification": "S2", "message": "Exibir apenas frente técnica sanitizada, sem PI sensível.", "created_at": "2026-06-19 21:40:53", "resolved_at": null, "company_name": "Vantion/LUNA", "agent_name": "Cerberus"}]};

const ENDPOINTS = {
  rooms:"/api/rooms", agents:"/api/agents", tasks:"/api/tasks",
  alerts:"/api/alerts", companies:"/api/companies", cycle:"/api/cycle"
};

/* ---- iso projection ---- */
const TILE_W=60, TILE_H=30, WALL=30, PAD=80;
const iso=(gx,gy)=>({x:(gx-gy)*TILE_W/2, y:(gx+gy)*TILE_H/2});
let OFF={x:0,y:0}, WORLD={w:0,h:0};
const P=(gx,gy)=>({x:iso(gx,gy).x+OFF.x, y:iso(gx,gy).y+OFF.y});

/* ---- runtime state ---- */
const reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;
const state = {
  mode:"offline", rooms:[], agents:[], tasks:[], alerts:[], companies:[],
  byRoom:{}, rt:{}, selectedAgentId:null, selectedRoomId:null,
  criticalRoomId:null, criticalAgentId:null, lastCycle:null
};
const $=s=>document.querySelector(s);
const esc=s=>String(s==null?"":s).replace(/[&<>"]/g,c=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;"}[c]));

/* ---- room visuals ---- */
const FURN = {
  executive:[["desk",.55,.45,.9,.5],["plant",.2,.2,.3,.3]],
  meeting:[["round",.5,.5,1.1,.7]],
  compliance:[["desk",.4,.4,.8,.45],["screen",.7,.7,.4,.3]],
  incubation:[["desk",.45,.5,.8,.45]],
  work:[["desk",.35,.4,.7,.4],["desk",.7,.6,.7,.4]],
  library:[["shelf",.25,.3,.35,1.0],["shelf",.7,.3,.35,1.0]],
  lab:[["bench",.4,.45,1.0,.5],["rack",.78,.7,.4,.4]],
  server_vault:[["rack",.3,.4,.4,.5],["rack",.55,.4,.4,.5],["core",.45,.7,.5,.5]],
  radar:[["dish",.5,.5,.8,.6]],
  sandbox:[["desk",.5,.5,.7,.45]],
  lounge:[["sofa",.4,.55,1.1,.5]]
};
function roomFloor(r){
  if(r.is_quarantine) return {top:"#4a2b78",fl:"#3b1d5f",wr:"#2a134a",wl:"#1c0c34"};
  if(r.company_risk>=5 || r.company_is_blocked) return {top:"#7a2230",fl:"#5a1620",wr:"#43101a",wl:"#310b12"};
  const lvl=(r.security_level||"S0");
  if(lvl>="S3") return {top:"#27405a",fl:"#1c3247",wr:"#122435",wl:"#0c1b29"};
  return {top:"#1d4258",fl:"#16344a",wr:"#0d2334",wl:"#091a28"};
}

/* ---- SVG helpers ---- */
const SVGNS="http://www.w3.org/2000/svg";
function poly(pts,fill,opts={}){
  const el=document.createElementNS(SVGNS,"polygon");
  el.setAttribute("points",pts.map(p=>p.x.toFixed(1)+","+p.y.toFixed(1)).join(" "));
  el.setAttribute("fill",fill);
  if(opts.stroke){el.setAttribute("stroke",opts.stroke);el.setAttribute("stroke-width",opts.sw||1);}
  if(opts.cls)el.setAttribute("class",opts.cls);
  if(opts.data)el.setAttribute("data-room",opts.data);
  if(opts.opacity!=null)el.setAttribute("opacity",opts.opacity);
  return el;
}
function up(p,h){return {x:p.x,y:p.y-h};}

function isoBox(svg,gx,gy,w,d,h,colTop,colR,colL){
  const A=P(gx,gy),B=P(gx+w,gy),C=P(gx+w,gy+d),D=P(gx,gy+d);
  svg.appendChild(poly([up(D,h),up(C,h),C,D],colR));            // right face
  svg.appendChild(poly([up(B,h),up(C,h),C,B],colL));            // left/front face
  svg.appendChild(poly([up(A,h),up(B,h),up(C,h),up(D,h)],colTop,{stroke:"rgba(0,0,0,.25)",sw:.6})); // top
}
function furnitureFor(svg,r){
  const list=FURN[r.room_type]||[];
  list.forEach(([kind,fx,fy,fw,fh])=>{
    const gx=r.grid_col+(r.grid_w-fw)*fx, gy=r.grid_row+(r.grid_h-fh)*fy;
    const palette={
      desk:["#7a5733","#5d4327","#3e2d1a"], round:["#2c4a60","#203a4d","#152838"],
      screen:["#1a2c3a","#142433","#0d1925"], shelf:["#8a5a30","#6b4524","#4a3019"],
      bench:["#56697a","#3f5061","#293743"], rack:["#16222e","#0f1922","#0a1118"],
      core:["#8f5cff","#6a3fd6","#3b1d5f"], dish:["#0e5360","#0a3f4a","#062a31"],
      sofa:["#33566a","#264456","#172e3c"], plant:["#2f7d52","#236040","#16402a"]
    };
    const c=palette[kind]||["#445","#334","#223"];
    const h=(kind==="shelf")? WALL*0.7 : (kind==="rack"||kind==="core")? WALL*0.65 : WALL*0.34;
    isoBox(svg,gx,gy,fw,fh,h,c[0],c[1],c[2]);
  });
}

/* ---- build the world ---- */
function computeBounds(){
  let minX=1e9,minY=1e9,maxX=-1e9,maxY=-1e9;
  state.rooms.forEach(r=>{
    [[r.grid_col,r.grid_row],[r.grid_col+r.grid_w,r.grid_row],
     [r.grid_col+r.grid_w,r.grid_row+r.grid_h],[r.grid_col,r.grid_row+r.grid_h]]
     .forEach(([c,rw])=>{const p=iso(c,rw);minX=Math.min(minX,p.x);maxX=Math.max(maxX,p.x);
        minY=Math.min(minY,p.y-WALL);maxY=Math.max(maxY,p.y);});
  });
  OFF={x:-minX+PAD, y:-minY+PAD};
  WORLD={w:(maxX-minX)+PAD*2, h:(maxY-minY)+PAD*2+50};
}
function buildWorld(){
  computeBounds();
  const svg=$("#floorplan"); svg.setAttribute("width",WORLD.w); svg.setAttribute("height",WORLD.h);
  svg.setAttribute("viewBox",`0 0 ${WORLD.w} ${WORLD.h}`); svg.innerHTML="";
  $("#tokens").style.width=WORLD.w+"px"; $("#tokens").style.height=WORLD.h+"px";

  const ordered=[...state.rooms].sort((a,b)=>(a.grid_col+a.grid_row)-(b.grid_col+b.grid_row));
  ordered.forEach(r=>{
    const c=roomFloor(r);
    const A=P(r.grid_col,r.grid_row), B=P(r.grid_col+r.grid_w,r.grid_row),
          C=P(r.grid_col+r.grid_w,r.grid_row+r.grid_h), D=P(r.grid_col,r.grid_row+r.grid_h);
    // back walls (raised) on the two far edges A-B and A-D
    svg.appendChild(poly([A,B,up(B,WALL),up(A,WALL)],c.wr,{stroke:"rgba(0,0,0,.3)",sw:.7}));
    svg.appendChild(poly([A,D,up(D,WALL),up(A,WALL)],c.wl,{stroke:"rgba(0,0,0,.3)",sw:.7}));
    // floor (clickable)
    const fl=poly([A,B,C,D],c.fl,{stroke:"rgba(0,0,0,.35)",sw:1,data:r.id,cls:"floor"});
    fl.style.cursor="pointer"; fl.addEventListener("click",e=>{e.stopPropagation();selectRoom(r.id);});
    svg.appendChild(fl);
    // subtle floor grid
    for(let i=1;i<r.grid_w;i++){const a=P(r.grid_col+i,r.grid_row),b=P(r.grid_col+i,r.grid_row+r.grid_h);
      const l=document.createElementNS(SVGNS,"line");l.setAttribute("x1",a.x);l.setAttribute("y1",a.y);l.setAttribute("x2",b.x);l.setAttribute("y2",b.y);l.setAttribute("stroke","rgba(255,255,255,.04)");svg.appendChild(l);}
    for(let j=1;j<r.grid_h;j++){const a=P(r.grid_col,r.grid_row+j),b=P(r.grid_col+r.grid_w,r.grid_row+j);
      const l=document.createElementNS(SVGNS,"line");l.setAttribute("x1",a.x);l.setAttribute("y1",a.y);l.setAttribute("x2",b.x);l.setAttribute("y2",b.y);l.setAttribute("stroke","rgba(255,255,255,.04)");svg.appendChild(l);}
    furnitureFor(svg,r);
    // room label
    const lp=up(P(r.grid_col+r.grid_w/2, r.grid_row),8);
    const t=document.createElementNS(SVGNS,"text");
    t.setAttribute("x",lp.x);t.setAttribute("y",lp.y);t.setAttribute("text-anchor","middle");
    t.setAttribute("fill","rgba(234,243,251,.62)");t.setAttribute("font-size","10");t.setAttribute("font-weight","600");
    t.setAttribute("letter-spacing",".04em");t.style.pointerEvents="none";
    t.textContent=(r.security_level?r.security_level+" · ":"")+r.name;
    svg.appendChild(t);
  });
  buildTokens();
}

/* ---- tokens & life ---- */
function roomCenter(roomId){
  const r=state.rooms.find(x=>x.id===roomId);
  return r?{gx:r.grid_col+r.grid_w/2, gy:r.grid_row+r.grid_h/2}:{gx:6,gy:5};
}
function jitter(i,n){const ang=(i/Math.max(1,n))*Math.PI*2;return {dx:Math.cos(ang)*0.5,dy:Math.sin(ang)*0.35};}

function buildTokens(){
  const layer=$("#tokens"); layer.innerHTML="";
  state.byRoom={};
  state.agents.forEach(a=>{(state.byRoom[a.current_room_id]=state.byRoom[a.current_room_id]||[]).push(a.id);});

  state.agents.forEach(a=>{
    const peers=state.byRoom[a.current_room_id]||[a.id];
    const idx=peers.indexOf(a.id);
    const c=roomCenter(a.current_room_id); const j=jitter(idx,peers.length);
    const home={gx:c.gx+j.dx, gy:c.gy+j.dy};
    if(!state.rt[a.id]) state.rt[a.id]={gx:home.gx,gy:home.gy,tx:home.gx,ty:home.gy,queue:[],next:0,walking:false};
    else { state.rt[a.id].home=home; setTarget(a.id,home.gx,home.gy); }
    state.rt[a.id].home=home;

    const el=document.createElement("div");
    el.className="agent "+behaviorClass(a); el.id="tk-"+a.id; el.style.setProperty("--c",a.visual_color||"#8aa1b6");
    el.innerHTML=`<div class="agent-bubble">${esc(stateLabel(a.state))}</div>
      <div class="agent-body">${esc(a.avatar_symbol||"●")}</div>
      <div class="agent-name">${esc(shortName(a.name))}</div>`;
    el.addEventListener("click",e=>{e.stopPropagation();selectAgent(a.id);});
    layer.appendChild(el);
    placeToken(a.id);
  });
  applySelectionStyles();
}
function shortName(n){return String(n||"").split(" ")[0];}
function stateLabel(s){return ({aguardando_favini:"aguardando Favini",lendo_documento:"lendo",exige_juridico:"exige jurídico",red_team:"red team"})[s]||(s||"").replace(/_/g," ");}
function behaviorClass(a){
  const s=a.state||"";
  if(a.is_blocked) return "st-quar crit";
  if(s.includes("quarentena")) return "st-quar";
  if(s.includes("aguardando")) return "st-wait";
  if(s.includes("juridico")) return "st-legal";
  if(s.includes("auditando")||s.includes("red_team")) return "st-audit";
  if(s.includes("trabalhando")||s.includes("lendo")) return "st-working";
  return "st-idle";
}
function canWander(a){const s=a.state||"";return !a.is_blocked && !s.includes("quarentena") && !s.includes("aguardando");}

function placeToken(id){
  const rt=state.rt[id]; const el=document.getElementById("tk-"+id); if(!rt||!el)return;
  const p=P(rt.gx,rt.gy);
  el.style.left=p.x+"px"; el.style.top=p.y+"px";
  el.style.zIndex=String(5+Math.round(rt.gx+rt.gy));
}
function setTarget(id,gx,gy){const rt=state.rt[id];if(!rt)return;rt.tx=gx;rt.ty=gy;rt.queue=[];}
function walkTo(id,gx,gy){
  const rt=state.rt[id]; if(!rt)return;
  // L-path through corridor row to read like "walking the halls"
  const CY=5.3;
  rt.queue=[{gx:rt.gx,gy:CY},{gx:gx,gy:CY},{gx:gx,gy:gy}];
  nextWaypoint(id);
}
function nextWaypoint(id){const rt=state.rt[id];if(!rt||!rt.queue.length){return;}const w=rt.queue.shift();rt.tx=w.gx;rt.ty=w.gy;}

let lastT=0;
function loop(t){
  const dt=Math.min(0.05,(t-lastT)/1000||0); lastT=t;
  const SPEED=2.4; // grid cells / sec
  state.agents.forEach(a=>{
    const rt=state.rt[a.id]; if(!rt)return;
    const dx=rt.tx-rt.gx, dy=rt.ty-rt.gy, dist=Math.hypot(dx,dy);
    const el=document.getElementById("tk-"+a.id);
    if(dist>0.02){
      const step=reduced?dist:Math.min(dist,SPEED*dt);
      rt.gx+=dx/dist*step; rt.gy+=dy/dist*step; rt.walking=true;
      el&&el.classList.add("walking"); placeToken(a.id);
    }else{
      rt.gx=rt.tx; rt.gy=rt.ty;
      if(rt.queue.length){ nextWaypoint(a.id); }
      else if(rt.walking){ rt.walking=false; el&&el.classList.remove("walking"); placeToken(a.id); }
    }
  });
  if(!reduced) maybeAmbient(t);
  requestAnimationFrame(loop);
}
/* ambient life: occasionally an eligible agent strolls to the lounge corridor and back.
   purely cosmetic — the agent always returns to its REAL room (rt.home). */
let ambientAt=0;
function maybeAmbient(t){
  if(t<ambientAt) return; ambientAt=t+4200+Math.random()*4000;
  const pool=state.agents.filter(a=>canWander(a) && state.rt[a.id] && !state.rt[a.id].walking && !state.rt[a.id].queue.length && a.id!==state.criticalAgentId);
  if(!pool.length) return;
  const a=pool[Math.floor(Math.random()*pool.length)]; const rt=state.rt[a.id];
  const h=rt.home||{gx:rt.gx,gy:rt.gy};
  const spot={gx:h.gx+(Math.random()*1.4-0.7), gy:5.3};
  rt.queue=[{gx:h.gx,gy:5.3},{gx:spot.gx,gy:spot.gy}];
  setTimeout(()=>{ if(state.rt[a.id]) walkBackHome(a.id); }, 2600+Math.random()*2200);
  nextWaypoint(a.id);
}
function walkBackHome(id){const rt=state.rt[id];if(!rt)return;const h=rt.home||{gx:rt.gx,gy:rt.gy};rt.queue=[{gx:h.gx,gy:5.3},{gx:h.gx,gy:h.gy}];nextWaypoint(id);}

/* ---- selection / panels ---- */
function applySelectionStyles(){
  state.agents.forEach(a=>{const el=document.getElementById("tk-"+a.id);if(!el)return;
    el.classList.toggle("sel",a.id===state.selectedAgentId);
    el.classList.toggle("crit",a.id===state.criticalAgentId||!!a.is_blocked);});
  document.querySelectorAll("#floorplan .floor").forEach(f=>{
    const rid=Number(f.getAttribute("data-room"));
    f.setAttribute("opacity", (state.selectedRoomId && rid!==state.selectedRoomId)?"0.5":"1");
    f.setAttribute("stroke", rid===state.criticalRoomId?"#ff4d5a":(rid===state.selectedRoomId?"#d6ad60":"rgba(0,0,0,.35)"));
    f.setAttribute("stroke-width", (rid===state.criticalRoomId||rid===state.selectedRoomId)?"2.4":"1");
  });
}
function selectAgent(id){
  state.selectedAgentId=id; const a=state.agents.find(x=>x.id===id);
  $("#insp-tag").textContent=a?shortName(a.name):"nenhum";
  const box=$("#inspector");
  if(!a){box.innerHTML='<div class="empty">Clique num agente.</div>';return;}
  const s4=(a.data_access_level||"").startsWith("S4");
  box.innerHTML=`
    <div class="insp-head">
      <div class="insp-avatar" style="--c:${esc(a.visual_color)}">${esc(a.avatar_symbol||"●")}</div>
      <div><div class="nm">${esc(a.name)}</div><div class="rl">${esc(a.role)}</div></div>
    </div>
    <dl class="kv">
      <dt>Estado</dt><dd>${esc(stateLabel(a.state))}</dd>
      <dt>Sala</dt><dd>${esc(a.room_name||"n/d")}</dd>
      <dt>Acesso</dt><dd><span class="chip ${s4?"s4":""}">${esc(a.data_access_level)}</span></dd>
      <dt>Pode bloquear</dt><dd>${a.can_block?"sim":"não"}</dd>
      <dt>Bloqueado</dt><dd>${a.is_blocked?'<span class="chip block">sim</span>':"não"}</dd>
      <dt>XP</dt><dd>${a.xp}</dd>
    </dl>`;
  applySelectionStyles();
}
function selectRoom(id){
  state.selectedRoomId = state.selectedRoomId===id?null:id;
  const r=state.rooms.find(x=>x.id===state.selectedRoomId);
  $("#task-filter").textContent=r?r.name:"todas as salas";
  applySelectionStyles(); renderTasks();
}
function renderTasks(){
  const box=$("#tasks");
  let list=state.tasks;
  if(state.selectedRoomId) list=list.filter(t=>t.room_id===state.selectedRoomId);
  if(!list.length){box.innerHTML='<div class="empty">Nenhuma tarefa para este filtro.</div>';return;}
  box.innerHTML=list.map(t=>`
    <div class="task ${esc(t.status)}">
      <div class="t">${esc(t.title)}</div>
      <div class="m">
        <span class="pri ${esc(t.priority)}">${esc(t.priority)}</span>
        <span class="st">${esc(t.status)}</span>
        ${t.room_name?`<span class="st">${esc(t.room_name)}</span>`:""}
      </div>
    </div>`).join("");
}

/* ---- status bar ---- */
function renderStatusBar(){
  const p0=state.tasks.find(t=>t.priority==="P0");
  const openAlerts=state.alerts.filter(a=>(a.status||"open")==="open").length;
  $("#sb-p0").innerHTML="P0: <b>"+esc(p0?p0.title:"n/d")+"</b>";
  $("#sb-alerts").innerHTML="Alertas abertos: <b>"+openAlerts+"</b>";
  const crit=state.lastCycle?.critical_company;
  if(crit) $("#sb-critical").innerHTML="Frente crítica: <b>"+esc(crit.name)+"</b>";
  $("#sb-ext").innerHTML="Ação externa: <b>0</b>";
}

/* ---- data loading ---- */
async function getJSON(url){const r=await fetch(url,{headers:{Accept:"application/json"}});if(!r.ok)throw new Error(url+" "+r.status);return r.json();}
function pick(obj,key){if(Array.isArray(obj))return obj;if(obj&&Array.isArray(obj[key]))return obj[key];return [];}

async function loadAll(initial){
  try{
    const [rm,ag,tk,al,co]=await Promise.all([
      getJSON(ENDPOINTS.rooms),getJSON(ENDPOINTS.agents),getJSON(ENDPOINTS.tasks),
      getJSON(ENDPOINTS.alerts),getJSON(ENDPOINTS.companies)]);
    state.mode="live";
    state.rooms=pick(rm,"rooms"); state.agents=pick(ag,"agents"); state.tasks=pick(tk,"tasks");
    state.alerts=pick(al,"alerts"); state.companies=pick(co,"companies");
  }catch(e){
    state.mode="offline";
    state.rooms=SNAPSHOT.rooms; state.agents=SNAPSHOT.agents; state.tasks=SNAPSHOT.tasks;
    state.alerts=SNAPSHOT.alerts; state.companies=SNAPSHOT.companies;
  }
  enrichRooms();
  setMode();
  if(initial) buildWorld(); else buildTokens();
  renderTasks(); renderStatusBar();
}
function enrichRooms(){
  const cmap={}; state.companies.forEach(c=>cmap[c.id]=c);
  state.rooms.forEach(r=>{const c=cmap[r.company_id];
    r.company_risk = r.company_risk ?? (c?c.risk_level:0);
    r.company_is_blocked = c?c.is_blocked:0;});
}
function setMode(){
  const el=$("#mode");el.className="mode-pill "+state.mode;
  $("#mode-label").textContent = state.mode==="live"?"AO VIVO · SQLite local":"PRÉVIA OFFLINE · snapshot v0.4.2";
}

/* ---- cycle ---- */
async function runCycle(){
  const btn=$("#btn-cycle"); btn.disabled=true;
  if(state.mode==="offline"){ simulateCyclePreview(); btn.disabled=false; return; }
  try{
    const res=await fetch(ENDPOINTS.cycle,{method:"POST",headers:{"Content-Type":"application/json"},body:"{}"});
    const data=await res.json(); applyCycle(data.cycle);
  }catch(e){ toast("Falha ao rodar ciclo: "+e.message); }
  finally{ btn.disabled=false; }
}
function applyCycle(cy){
  if(!cy)return; state.lastCycle=cy;
  $("#sb-cycle").innerHTML="Ciclo #"+cy.id+" · "+(cy.created_at||"");
  state.criticalRoomId = cy.critical_task?.room_id || null;
  state.criticalAgentId = cy.blocked_agent?.id || null;
  if(cy.critical_company) $("#sb-critical").innerHTML="Frente crítica: <b>"+esc(cy.critical_company.name)+"</b>";
  // bring the critical agent to centre stage (visual choreography), then home
  if(state.criticalAgentId && state.rt[state.criticalAgentId]){
    selectAgent(state.criticalAgentId);
    walkTo(state.criticalAgentId, 6, 5.3);
    setTimeout(()=>walkBackHome(state.criticalAgentId), 5200);
  }
  applySelectionStyles();
  toast(cy.summary || "Ciclo concluído. Nenhuma ação externa executada.");
}
function simulateCyclePreview(){
  // offline preview only: derive a plausible "critical" view from the snapshot itself (real rows)
  const crit=[...state.companies].sort((a,b)=>(b.is_blocked-a.is_blocked)||(b.risk_level-a.risk_level))[0];
  const p0=state.tasks.find(t=>t.priority==="P0")||state.tasks[0];
  const blocked=state.agents.find(a=>a.is_blocked)||state.agents.find(a=>a.state&&a.state.includes("quarentena"));
  applyCycle({id:"prévia",created_at:"offline",critical_company:crit,critical_task:p0,blocked_agent:blocked,
    summary:"Prévia offline: frente crítica "+(crit?crit.name:"n/d")+". Conecte o servidor para rodar o ciclo real."});
}

/* ---- camera ---- */
const cam={x:0,y:0,s:1};
function applyCam(){$("#world").style.transform=`translate(${cam.x}px,${cam.y}px) scale(${cam.s})`;}
function fit(){
  const vp=$("#viewport").getBoundingClientRect();
  cam.s=Math.min(1.15, Math.max(.42,(vp.width-40)/WORLD.w, (vp.height-80)/WORLD.h*0));
  cam.s=Math.min((vp.width-40)/WORLD.w,(vp.height-120)/WORLD.h);
  cam.s=Math.max(.4,Math.min(1.1,cam.s));
  cam.x=(vp.width-WORLD.w*cam.s)/2; cam.y=(vp.height-WORLD.h*cam.s)/2-10; applyCam();
}
(function camControls(){
  const stage=$("#stage"); let drag=null;
  stage.addEventListener("pointerdown",e=>{if(e.target.closest(".agent")||e.target.closest(".zoomctl"))return;
    drag={x:e.clientX,y:e.clientY,cx:cam.x,cy:cam.y};stage.classList.add("dragging");stage.setPointerCapture(e.pointerId);});
  stage.addEventListener("pointermove",e=>{if(!drag)return;cam.x=drag.cx+(e.clientX-drag.x);cam.y=drag.cy+(e.clientY-drag.y);applyCam();});
  stage.addEventListener("pointerup",()=>{drag=null;stage.classList.remove("dragging");});
  stage.addEventListener("pointercancel",()=>{drag=null;stage.classList.remove("dragging");});
  stage.addEventListener("click",e=>{if(e.target.id==="viewport"||e.target.id==="stage"){state.selectedAgentId=null;$("#insp-tag").textContent="nenhum";$("#inspector").innerHTML='<div class="empty">Clique num agente no escritório para ver sua ficha.</div>';applySelectionStyles();}});
  stage.addEventListener("wheel",e=>{e.preventDefault();zoomAt(e.clientX,e.clientY,e.deltaY<0?1.12:1/1.12);},{passive:false});
  $("#zoom-in").addEventListener("click",()=>{const r=$("#stage").getBoundingClientRect();zoomAt(r.left+r.width/2,r.top+r.height/2,1.18);});
  $("#zoom-out").addEventListener("click",()=>{const r=$("#stage").getBoundingClientRect();zoomAt(r.left+r.width/2,r.top+r.height/2,1/1.18);});
})();
function zoomAt(px,py,f){
  const stage=$("#stage").getBoundingClientRect(); const mx=px-stage.left,my=py-stage.top;
  const ns=Math.max(.34,Math.min(1.7,cam.s*f)); const k=ns/cam.s;
  cam.x=mx-(mx-cam.x)*k; cam.y=my-(my-cam.y)*k; cam.s=ns; applyCam();
}

/* ---- toast ---- */
let toastT;function toast(m){const t=$("#toast");t.textContent=m;t.classList.add("show");clearTimeout(toastT);toastT=setTimeout(()=>t.classList.remove("show"),5200);}

/* ---- boot ---- */
$("#btn-cycle").addEventListener("click",runCycle);
$("#btn-refresh").addEventListener("click",()=>loadAll(false).then(()=>toast("Dados atualizados ("+state.mode+").")));
$("#btn-reset").addEventListener("click",fit);
window.addEventListener("resize",()=>{/* keep camera; just clamp */ applyCam();});

(async function start(){
  await loadAll(true);
  fit();
  // entrance: agents walk in from corridor to their rooms
  state.agents.forEach((a,i)=>{const rt=state.rt[a.id];if(!rt)return;const h=rt.home;rt.gx=6;rt.gy=5.3;rt.tx=6;rt.ty=5.3;
    setTimeout(()=>walkTo(a.id,h.gx,h.gy), reduced?0:120*i);});
  requestAnimationFrame(loop);
})();
</script>
</body>
</html>
